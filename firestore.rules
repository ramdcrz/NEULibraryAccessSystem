
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU Library Access System - Security Rules
     * 
     * Core Philosophy:
     * This ruleset implements a strict hierarchical ownership model combined with role-based access control (RBAC).
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the authenticated user is NOT blocked from the system. */
    function isNotBlocked() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc == null || userDoc.data.get('is_blocked', false) == false;
    }

    /** @description Checks if the authenticated user has the 'admin' role. 
     *  Uses a direct lookup with a default value.
     */
    function isAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin';
    }

    /** @description Combines ownership and existence check for updates and deletes. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profile documents.
     */
    match /users/{userId} {
      // prevent recursion: only call isAdmin() if the request isn't for the current user's own record
      allow get: if isOwner(userId) || (request.auth.uid != userId && isAdmin());
      allow list: if isAdmin();
      allow create: if (isOwner(userId) && request.resource.data.get('id', '') == userId);
      allow update: if (isExistingOwner(userId) && request.resource.data.get('id', '') == resource.data.get('id', '')) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Rules for individual visit log entries nested under a user.
     */
    match /users/{userId}/visit_logs/{visitLogId} {
      allow get: if (isOwner(userId) && isNotBlocked()) || isAdmin();
      allow list: if (isOwner(userId) && isNotBlocked()) || isAdmin();
      allow create: if (isOwner(userId) && isNotBlocked() && request.resource.data.userId == userId) || isAdmin();
      allow update: if (isExistingOwner(userId) && isNotBlocked() && request.resource.data.userId == resource.data.userId) || isAdmin();
      allow delete: if (isExistingOwner(userId) && isNotBlocked()) || isAdmin();
    }

    /**
     * @description Collection Group rules for visit logs to support administrative reporting.
     * This rule is specifically used by the collectionGroup('visit_logs') query in the Admin Dashboard.
     */
    match /{path=**}/visit_logs/{visitLogId} {
      allow read: if isAdmin();
    }
  }
}
