
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the user signed in?
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Is the requester an admin?
    // This helper performs a cross-document lookup to the users collection.
    function isSystemAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 1. VISIT LOGS (FLAT TOP-LEVEL COLLECTION)
    match /visit_logs/{logId} {
      // allow create: Any signed-in user can log their own visit.
      // Updated to check 'uid' field to match new schema.
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      
      // allow read, list: Admins can see all logs. Users can see their own logs.
      allow read, list: if isSignedIn() && (
        (resource != null && resource.data.uid == request.auth.uid) || 
        isSystemAdmin()
      );
    }

    // 2. USER PROFILE RULES
    match /users/{userId} {
      // Base case for self-access to prevent recursion loops
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      // Allow admins to access other user records
      allow read, write: if isSystemAdmin();
    }
  }
}
