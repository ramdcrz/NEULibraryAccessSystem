rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Basic Helpers ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Admin Check ---
    // We use a direct path check to avoid recursion issues in complex queries
    function isAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // Allow user to manage their own profile, and admins to manage all profiles
      allow read, write: if isOwner(userId) || isAdmin();

      match /visit_logs/{visitLogId} {
        // Simple ownership or admin check
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // --- Collection Group Rules ---
    // This is critical for the Admin Analytics Dashboard
    match /{path=**}/visit_logs/{visitLogId} {
      allow read: if isAdmin();
    }
  }
}