rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the user signed in?
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Is the requester an admin?
    // This function is now only called when necessary to avoid recursion.
    function isSystemAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 1. COLLECTION GROUP RULE (CRITICAL)
    // This targets the Admin Dashboard query: collectionGroup(db, 'visit_logs')
    // We place this at the top level to ensure clear evaluation.
    match /{path=**}/visit_logs/{logId} {
      // Permission check for listing all logs
      allow list: if isSystemAdmin();
      // Permission check for individual log access
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isSystemAdmin());
    }

    // 2. USER DOCUMENT RULES
    match /users/{userId} {
      // BASE CASE: User reading their own profile.
      // We MUST check UID ownership first without calling isSystemAdmin().
      // This is the "Base Case" that breaks the recursion loop.
      allow read: if isSignedIn() && request.auth.uid == userId;

      // Allow admins to read other users' profiles.
      // This only triggers if the first rule fails (i.e., requesting someone else's profile).
      allow read: if isSignedIn() && request.auth.uid != userId && isSystemAdmin();

      // Write rules
      allow write: if isSignedIn() && (request.auth.uid == userId || isSystemAdmin());

      // Nested visit logs (Direct path access)
      match /visit_logs/{logId} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isSystemAdmin());
        allow create: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}