rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Is the user signed in?
    function isSignedIn() {
      return request.auth != null;
    }

    // BASE RULE: A user can always read/write their own document.
    // This MUST be the first rule to prevent recursion in admin checks.
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      // ALLOW admins to manage any user profile.
      // This lookup will match the base rule above for the admin's own document.
      allow read, write: if isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';

      // Rules for nested visit logs.
      match /visit_logs/{logId} {
        allow read, write: if isSignedIn() && (
          request.auth.uid == userId || 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        );
      }
    }

    // COLLECTION GROUP RULE: For the Admin Analytics dashboard.
    // Matches all 'visit_logs' collections anywhere in the database.
    match /{path=**}/visit_logs/{logId} {
      allow read: if isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}