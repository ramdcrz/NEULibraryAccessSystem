rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Is the user signed in?
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Get user role (Optimized for non-recursion)
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 1. COLLECTION GROUP RULE
    // This MUST be top-level and explicitly allow 'list' for the group query to work.
    match /{path=**}/visit_logs/{logId} {
      allow read: if isAdmin();
    }

    // 2. USER DOCUMENT RULES
    match /users/{userId} {
      // BASE RULE: Ownership allows read/write without calling isAdmin()
      // This breaks the recursion loop during role lookups.
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      // Allow admins to manage profiles
      allow read, write: if isAdmin();

      // Rules for nested visit logs (for direct access)
      match /visit_logs/{logId} {
        allow read, write: if isSignedIn() && (
          request.auth.uid == userId || isAdmin()
        );
      }
    }
  }
}