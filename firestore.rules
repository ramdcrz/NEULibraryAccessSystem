rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Authorization Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    // BASE CASE: Allow users to read their own profile without any recursion.
    // This MUST be defined outside or before any admin-check helpers to prevent loops.
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      
      // Allow the owner to write their own data
      allow write: if isSignedIn() && request.auth.uid == userId;

      // Allow Admins to manage profiles (this will call get() which is safe now)
      allow read, write: if isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';

      // --- Nested Visit Logs ---
      match /visit_logs/{visitLogId} {
        // Owners can read/write their own logs
        allow read, write: if isSignedIn() && request.auth.uid == userId;
        // Admins can read/write any log
        allow read, write: if isSignedIn() && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      }
    }

    // --- Collection Group Rules ---
    // Matches all 'visit_logs' collections for the Admin Dashboard query.
    match /{path=**}/visit_logs/{visitLogId} {
      // Direct admin check for the collection group query
      allow read: if isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}