rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Is the user signed in?
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Is the requester an admin?
    // This performs a lookup. We must ensure the rules for the user doc itself
    // don't call this function to avoid recursion.
    function isSystemAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 1. COLLECTION GROUP RULE
    // This targets the Admin Dashboard query: collectionGroup(db, 'visit_logs')
    // It must be at the top level to catch collectionGroup requests.
    match /{path=**}/visit_logs/{logId} {
      allow list: if isSystemAdmin();
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isSystemAdmin());
    }

    // 2. USER DOCUMENT RULES
    match /users/{userId} {
      // BASE RULE: Ownership check. 
      // CRITICAL: We DO NOT call isSystemAdmin() here. 
      // This allows the admin to read their OWN document (which is required for 
      // isSystemAdmin() to work in other rules) without causing a recursion loop.
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      // Secondary rule for admins to manage OTHER users.
      // This call to isSystemAdmin is safe because if the user is checking 
      // their own doc, the rule above will have already matched.
      allow read, write: if isSystemAdmin();

      // Rules for nested visit logs (direct path access)
      match /visit_logs/{logId} {
        allow read, write: if isSignedIn() && (
          request.auth.uid == userId || isSystemAdmin()
        );
        allow create: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}