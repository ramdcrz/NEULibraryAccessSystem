rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Authorization Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to get the requester's data.
    // This is used for role-based access control.
    function getRequesterData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // --- User Profile Rules ---
    match /users/{userId} {
      // BASE CASE: Users can always read and write their own profile.
      // This rule is evaluated FIRST and does not call any other functions.
      // This is critical to prevent recursive loops when admins check their own roles.
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      // ADMIN ACCESS: Allow admins to manage other profiles.
      // This calls getRequesterData() which triggers the 'Base Case' above for the admin's own doc.
      allow read, write: if isSignedIn() && getRequesterData().role == 'admin';

      // --- Nested Visit Logs ---
      match /visit_logs/{visitLogId} {
        // Owners can read/write their own logs
        allow read, write: if isSignedIn() && request.auth.uid == userId;
        // Admins can read/write any log
        allow read, write: if isSignedIn() && getRequesterData().role == 'admin';
      }
    }

    // --- Collection Group Rules ---
    // Matches all 'visit_logs' collections for the Admin Dashboard query.
    match /{path=**}/visit_logs/{visitLogId} {
      allow read: if isSignedIn() && getRequesterData().role == 'admin';
    }
  }
}