rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Basic Helpers ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Admin Check ---
    // This function performs a document lookup. 
    // IMPORTANT: The rules for the /users/{userId} path must allow reading 
    // if isOwner(userId) WITHOUT calling isAdmin() to avoid infinite recursion.
    function isAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // 1. Allow owners to read their own profile UNCONDITIONALLY to break isAdmin recursion.
      // 2. Allow owners to write their own profile.
      allow read, write: if isOwner(userId);
      
      // 3. Allow admins to read/write any profile. 
      // When isAdmin() calls get() on the admin's own doc, rule #1 above will satisfy it.
      allow read, write: if isAdmin();

      match /visit_logs/{visitLogId} {
        // Simple ownership or admin check
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // --- Collection Group Rules ---
    // This is critical for the Admin Analytics Dashboard.
    // It is placed outside nested matches for clarity.
    match /{path=**}/visit_logs/{visitLogId} {
      allow read: if isAdmin();
    }
  }
}