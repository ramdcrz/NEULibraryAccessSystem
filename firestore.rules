rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- User Profile Rules ---
    match /users/{userId} {
      // 1. Allow owners to read and write their own profile.
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      // 2. Allow admins to read/write any profile.
      // Explicitly check the role in the user's document.
      allow read, write: if isSignedIn() && 
                           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';

      // --- Nested Visit Logs ---
      match /visit_logs/{visitLogId} {
        // Owners can manage their own logs, Admins can manage everything.
        allow read, write: if (isSignedIn() && request.auth.uid == userId) || 
                             (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      }
    }

    // --- Collection Group Rules ---
    // Matches all 'visit_logs' collections across all users.
    match /{path=**}/visit_logs/{visitLogId} {
      // Access to ALL logs is restricted strictly to administrators.
      allow read: if isSignedIn() && 
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}