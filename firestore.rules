rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Is the user signed in?
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Check if user is an admin
    // This MUST NOT be used inside the /users/{userId} rule to avoid recursion
    function isSystemAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 1. COLLECTION GROUP RULE
    // This targets the Admin Dashboard query. 
    // It must be at the top level to catch collectionGroup requests.
    match /{path=**}/visit_logs/{logId} {
      allow list: if isSystemAdmin();
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isSystemAdmin());
    }

    // 2. USER DOCUMENT RULES
    match /users/{userId} {
      // BASE RULE: Ownership check comes first and DOES NOT call isSystemAdmin()
      // This is the critical "Base Case" that breaks the recursion loop.
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      // Secondary rule for admins (this call to isSystemAdmin is safe because 
      // the ownership check above will have already matched for the admin's own doc)
      allow read, write: if isSystemAdmin();

      // Rules for nested visit logs (for direct access via user path)
      match /visit_logs/{logId} {
        allow read, write: if isSignedIn() && (
          request.auth.uid == userId || isSystemAdmin()
        );
        allow create: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}