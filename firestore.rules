rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the user signed in?
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Is the requester an admin?
    // This helper performs a cross-document lookup to the users collection.
    function isSystemAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 1. VISIT LOGS (FLAT TOP-LEVEL COLLECTION)
    match /visit_logs/{logId} {
      // allow create: Any signed-in user can log their own visit.
      // We check that the userId field in the document matches the authenticated UID.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // allow read, list: Admins can see all logs. Users can see their own logs.
      // Note: order of evaluation is important to avoid unnecessary get() calls.
      allow read, list: if isSignedIn() && (
        (resource != null && resource.data.userId == request.auth.uid) || 
        isSystemAdmin()
      );
    }

    // 2. USER PROFILE RULES
    match /users/{userId} {
      // BASE CASE: User reading or writing their own profile.
      // This MUST come first to break the potential recursion loop when isSystemAdmin() 
      // is called from other rules, as isSystemAdmin() itself performs a get() on a user document.
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      // Allow admins to read or write other users' profiles.
      allow read, write: if isSystemAdmin();
    }
  }
}