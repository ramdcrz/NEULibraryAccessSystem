rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- User Profile Rules ---
    match /users/{userId} {
      // 1. Allow owners to read and write their own profile.
      // This rule is simple and does NOT call any other functions, preventing recursion.
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      // 2. Allow admins to read/write any profile.
      // We perform the role check directly here instead of using a helper function.
      allow read, write: if isSignedIn() && 
                           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';

      // --- Nested Visit Logs ---
      match /visit_logs/{visitLogId} {
        // Owners can manage their own logs, Admins can manage everything.
        allow read, write: if (isSignedIn() && request.auth.uid == userId) || 
                             (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      }
    }

    // --- Collection Group Rules ---
    // This is for the Admin Analytics Dashboard. 
    // It matches all 'visit_logs' collections regardless of where they are nested.
    match /{path=**}/visit_logs/{visitLogId} {
      // Strictly restrict collection group reads to verified admins only.
      allow read: if isSignedIn() && 
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}