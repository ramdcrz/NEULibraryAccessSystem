rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the user signed in?
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Is the requester an admin?
    // This helper performs a cross-document lookup.
    function isSystemAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 1. VISIT LOGS (FLAT TOP-LEVEL COLLECTION)
    match /visit_logs/{logId} {
      // Allow any signed-in user to create their own visit log.
      // The userId field in the document must match the creator's UID.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // Admins can read and list all visit logs for the dashboard.
      allow read, list: if isSystemAdmin();
      
      // Users can read their own specific log entries.
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 2. USER PROFILE RULES
    match /users/{userId} {
      // BASE CASE: User reading or writing their own profile.
      // We check UID ownership FIRST to break potential recursion loops when isSystemAdmin() is called.
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      // Allow admins to read or write other users' profiles.
      // This part only evaluates if the base case above is false.
      allow read, write: if isSystemAdmin();
    }
  }
}