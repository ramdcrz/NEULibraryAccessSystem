rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Authorization ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- User Profile Rules ---
    match /users/{userId} {
      // Base Case: Users can always read their own profile.
      // CRITICAL: We do NOT call a helper function here to avoid infinite recursion.
      allow read: if isSignedIn() && request.auth.uid == userId;
      
      // Admin Access: An admin can read any profile.
      // This calls get() on the admin's own profile, which hits the 'Base Case' rule above.
      allow read: if isSignedIn() && 
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';

      // Writes: Owners or Admins
      allow write: if isSignedIn() && (
        request.auth.uid == userId || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );

      // --- Nested Visit Logs ---
      match /visit_logs/{visitLogId} {
        allow read, write: if isSignedIn() && (
          request.auth.uid == userId || 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        );
      }
    }

    // --- Collection Group Rules ---
    // Matches all 'visit_logs' collections across the entire database.
    // This rule is evaluated when the Admin Dashboard runs its query.
    match /{path=**}/visit_logs/{visitLogId} {
      allow read: if isSignedIn() && 
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}