
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the user signed in?
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Is the requester an admin?
    // This helper performs a cross-document lookup to the users collection.
    function isSystemAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 1. VISIT LOGS
    match /visit_logs/{logId} {
      // Create: Any signed-in user can log their own visit.
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      
      // Update: Users can update (check-out) their own logs. Admins can manage all.
      allow update: if isSignedIn() && (
        resource.data.uid == request.auth.uid || 
        isSystemAdmin()
      );
      
      // Read/List: Admins can see all logs. Users can see their own logs (must use filtered query).
      allow read, list: if isSignedIn() && (
        isSystemAdmin() || 
        resource.data.uid == request.auth.uid
      );
    }

    // 2. USER PROFILE RULES
    match /users/{userId} {
      // Users can read/write their own profile. Admins can access all.
      allow read, write: if isSignedIn() && (
        request.auth.uid == userId || 
        isSystemAdmin()
      );
    }
  }
}
