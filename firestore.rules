rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the user signed in?
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Is the requester an admin?
    // We fetch the user document to check the role field.
    function isSystemAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 1. COLLECTION GROUP RULE
    // This targets collectionGroup(db, 'visit_logs')
    match /{path=**}/visit_logs/{logId} {
      // Admins can see everyone's logs. Users can only see their own (via direct path below).
      allow list: if isSystemAdmin();
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isSystemAdmin());
    }

    // 2. USER DOCUMENT RULES
    match /users/{userId} {
      // BASE CASE: User reading their own profile.
      // We check UID ownership FIRST and ALONE to break potential recursion loops.
      allow read: if isSignedIn() && request.auth.uid == userId;

      // Allow admins to read other users' profiles.
      // This only evaluates if the first rule fails.
      allow read: if isSignedIn() && isSystemAdmin();

      // Write rules
      allow write: if isSignedIn() && (request.auth.uid == userId || isSystemAdmin());

      // Nested visit logs (Direct path access)
      match /visit_logs/{logId} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isSystemAdmin());
        allow create: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}